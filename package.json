{
  "name": "trackflow",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:worker": "npm --workspace apps/worker run dev",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "prisma:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema packages/db/prisma/schema.prisma",
    "prisma:dev": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "seed": "tsx packages/db/prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.22.0",
    "@vitejs/plugin-react": "^4.3.4",
    "amqplib": "^0.10.4",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "fastify": "^4.28.1",
    "geoip-lite": "^1.4.10",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.9",
    "nodemailer": "^6.9.16",
    "pdfkit": "^0.15.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ua-parser-js": "^1.0.39",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/geoip-lite": "^1.4.4",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.13.8",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^6.0.2",
    "@types/ua-parser-js": "^0.7.39",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "tsx packages/db/prisma/seed.ts"
  }
}
